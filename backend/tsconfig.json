{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "rootDir": "./",            // <-- incluye src/ y lib/
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "lib/**/*.ts"],
  "exclude": ["node_modules", "dist"],
  "noImplicitAny": false
}
